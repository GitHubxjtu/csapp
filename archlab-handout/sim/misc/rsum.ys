# tanyonghuisapple
.pos 0
irmovq stack, %rsp
call main
halt

.align 8
ele1:
.quad 0x00a
.quad ele2
ele2:
.quad 0x0b0
.quad ele3
ele3:
.quad 0xc00
.quad 0

main:
     irmovq ele1, %rdi
     call rsum
     ret
rsum:
#     pushq %rax
     andq %rdi,%rdi
     je end_rsum
     mrmovq (%rdi), %r8
     pushq %r8
     mrmovq $8(%rdi), %rdi
     call rsum
     popq %r8
#     popq %rax
     addq %r8, %rax
     ret
end_rsum:
     xorq %rax, %rax
     ret

.pos 0x200
stack:
    .quad 0
    